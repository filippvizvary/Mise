# Database (default: SQLite for local dev; set to PostgreSQL for production)
# DATABASE_URL=postgresql://mise:mise@localhost:5432/mise

# Email Verification
EMAIL_VERIFICATION_REQUIRED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=mise@example.com

# AI Provider
MISE_AI_PROVIDER=ollama
MISE_AI_MODEL=glm-5.1

# Ollama
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Scraper
MISE_SCRAPER_TIMEOUT=30
MISE_SCRAPER_HEADLESS=true